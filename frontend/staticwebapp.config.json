{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/_next/*", "/assets/*", "/images/*", "/api/*"]
  },
  "routes": [
    {
      "route": "/chat/*",
      "serve": "/chat/index.html"
    },
    {
      "route": "/teacher/*",
      "serve": "/teacher/index.html"
    }
  ],
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY"
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}